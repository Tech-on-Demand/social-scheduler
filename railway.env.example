# Railway Environment Variables — social-scheduler
# Copy this file to .env and fill in values before deploying.

# ─── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string (Railway auto-sets this for linked Postgres plugin)
DATABASE_URL=postgresql://user:password@host:5432/social_scheduler

# ─── Auth ──────────────────────────────────────────────────────────────────────
# Comma-separated list of additional allowed emails (beyond brayden@techondemand.com.au)
ALLOWED_EMAILS=brayden@techondemand.com.au

# ─── Redis ─────────────────────────────────────────────────────────────────────
# Redis connection URL (Railway auto-sets this for linked Redis plugin)
REDIS_URL=redis://default:password@host:6379

# ─── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# Rate limiting (requests per hour per IP, default 30)
API_LIMIT=30

# ─── External Services ─────────────────────────────────────────────────────────
# JWT / session secret
JWT_SECRET=change-me-in-production

# Supabase (for SSO passthrough if used)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Email ─────────────────────────────────────────────────────────────────────
SENDGRID_API_KEY=SG.xxx
EMAIL_FROM=noreply@techondemand.com.au

# ─── Storage ───────────────────────────────────────────────────────────────────
CLOUDFLARE_ACCOUNT_ID=your-cf-account-id
CLOUDFLARE_ACCESS_KEY=your-cf-access-key
CLOUDFLARE_SECRET_KEY=your-cf-secret-key
CLOUDFLARE_BUCKET_NAME=social-media
CLOUDFLARE_BUCKET_URL=https://your-bucket.r2.cloudflarestorage.com

# ─── Sentry ────────────────────────────────────────────────────────────────────
SENTRY_DSN=https://xxx@sentry.io/xxx

# ─── AI / LLM ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-xxx

# ─── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
